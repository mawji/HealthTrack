# ── Google Health API (Fitbit data, real-time + food write-back) ──
# Setup (see README for detail):
#   1. console.cloud.google.com → create a project → enable "Google Health API"
#   2. OAuth consent screen → add yourself as a test user
#   3. Credentials → Create OAuth client ID → "Web application"
#      Authorized redirect URI (exactly):
#        http://localhost:3210/api/googlehealth/callback
GOOGLE_HEALTH_CLIENT_ID=your_google_health_client_id_here
GOOGLE_HEALTH_CLIENT_SECRET=your_google_health_client_secret_here

# ── AI providers ───────────────────────────────────────────────────
# Connect any one of the providers below. You can also connect them
# via the Settings page in the app instead of editing this file.

# OpenRouter (default — text via Cerebras, vision via any provider)
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-oss-120b
OPENROUTER_PROVIDER=cerebras
OPENROUTER_VISION_MODEL=meta-llama/llama-4-scout

# OpenAI — API key (https://platform.openai.com/api-keys)
# OPENAI_API_KEY_DIRECT=sk-proj-...
# (Enter in Settings → AI Provider → ChatGPT (API Key))

# OpenAI — OAuth (ChatGPT subscription, no credentials needed)
# Connect via Settings → AI Provider → ChatGPT (Subscription) → Connect
# Uses device code flow: enter the displayed code at https://auth.openai.com/codex/device

# Gemini — API key (https://aistudio.google.com/apikey)
# (Enter in Settings → AI Provider → Gemini (API Key))

# Anthropic Claude — API key (https://console.anthropic.com)
# (Enter in Settings → AI Provider → Anthropic Claude)

# Ollama (local models — install from https://ollama.ai)
# No credentials needed; configure URL and model in Settings → AI Provider → Ollama.
# Default URL: http://localhost:11434

# ── Timezone ───────────────────────────────────────────────────────
# Timezone your health data lives in (your devices' timezone, which can
# differ from this PC's clock).
APP_TZ=Asia/Dubai

# ── App ────────────────────────────────────────────────────────────
# Port 3000 is OS-reserved on some machines, so the app runs on 3210.
APP_BASE_URL=http://localhost:3210
