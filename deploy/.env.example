# HealthTrack — production deployment settings. Copy to `.env` and fill in.
# This is the ONLY file you edit. compose.yml / serve.json read everything from here.
# Most other settings (AI provider, Telegram, etc.) are configured in the app's
# Settings UI after first launch, not here. See docs/docker-deployment-runbook.html.

# ── Required ─────────────────────────────────────────────────────────────────

# Google Health API (your health data). console.cloud.google.com → enable the
# Google Health API → OAuth consent (add yourself as a test user) → Credentials →
# create an OAuth client (Web application). Then add this redirect URI exactly:
#   <APP_BASE_URL>/api/googlehealth/callback
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=

# Your public app URL = https://<TS_HOSTNAME>.<your-tailnet>.ts.net
# install.sh auto-fills this after Tailscale connects; otherwise set it by hand.
# It is BOTH the OAuth redirect base and what the in-container workers call.
APP_BASE_URL=

# Timezone your health data lives in (IANA name), e.g. Asia/Dubai, Europe/London.
APP_TZ=Asia/Dubai

# Tailscale: the machine name (→ your *.ts.net hostname) and a one-time auth key
# from the admin console (Settings → Keys → Generate auth key; reusable is handy).
TS_HOSTNAME=healthtrack
TS_AUTHKEY=

# Watchtower update-endpoint token. Any long random string; install.sh generates one.
WATCHTOWER_TOKEN=

# ── Image source (defaults are fine) ─────────────────────────────────────────
# Which GHCR image + channel the stack pulls. Override only for forks / beta.
GHCR_OWNER=mawji
CHANNEL=stable

# ── Optional ─────────────────────────────────────────────────────────────────

# Telegram bot (enables the bot, reminders-to-Telegram, sharing). Can also be set
# in Settings instead. From @BotFather.
# TELEGRAM_BOT_TOKEN=

# USDA FoodData Central key (better food macros). Free: https://fdc.nal.usda.gov/api-key-signup.html
# Without it a shared, rate-limited demo key is used.
# USDA_FDC_API_KEY=

# OpenAI key — only a cloud fallback for voice transcription if local Whisper fails.
# OPENAI_API_KEY=

# Local hour (0–23) for the daily self-report. Default 8.
# PROACTIVE_REPORT_HOUR=8
